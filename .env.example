# Identifiants de connexion à l'application
APP_USERNAME=admin
APP_PASSWORD=votre-mot-de-passe-ici

# Clé secrète de session (mettez une longue chaîne aléatoire)
SESSION_SECRET=changez-cette-valeur-par-une-chaine-aleatoire-longue

# Gmail (optionnel : pré-configure l'envoi côté serveur)
GMAIL_USER=votre.email@gmail.com
GMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx

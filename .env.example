# ── Identifiants de l'application ─────────────────────────────────────────────
APP_USERNAME=admin
APP_PASSWORD=votre-mot-de-passe-ici

# ── Clé secrète de session ─────────────────────────────────────────────────────
SESSION_SECRET=changez-cette-valeur-par-une-chaine-aleatoire-longue

# ── Email expéditeur (pré-configure l'envoi côté serveur) ─────────────────────
SENDER_EMAIL=prenom.nom@domaine.com
SENDER_PASSWORD=votre-mot-de-passe-ou-app-password

# ── Serveur SMTP (facultatif — si laissé vide, détection automatique) ─────────
# Carrefour / Office 365 → smtp.office365.com
# Gmail                  → (laisser vide, détecté automatiquement)
# Autre entreprise       → renseignez votre serveur SMTP ci-dessous
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
